{
  "name": "reconvo",
  "version": "0.1.0",
  "description": "Human- and agent-friendly CLI to search Claude Code and OpenCode sessions",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/awhitty/reconvo.git"
  },
