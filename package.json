{
  "name": "reconvo",
  "version": "0.2.0",
  "description": "Human- and agent-friendly CLI to search Claude Code and OpenCode sessions",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/awhitty/reconvo.git"
  },
  "keywords": ["claude-code", "opencode", "ai", "conversation", "search", "cli", "duckdb"],
  "engines": {
    "node": ">=18",
    "bun": ">=1.0"
  },
  "bin": {
    "reconvo": "./dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "bun build src/cli.ts --outdir dist --target node --external duckdb && sed -i '' '1s|#!/usr/bin/env bun|#!/usr/bin/env node|' dist/cli.js",
    "prepublishOnly": "bun run build",
    "dev": "bun run src/cli.ts",
    "test": "bun test --timeout 30000",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "5.8.2",
    "@types/bun": "1.2.9"
  },
  "dependencies": {
    "duckdb": "^1.4.4"
  }
}
